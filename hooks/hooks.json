{
  "description": "Superscraper plugin hooks for session initialization and auto-activation",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/session-start",
            "timeout": 5
          }
        ]
      }
    ]
  }
}